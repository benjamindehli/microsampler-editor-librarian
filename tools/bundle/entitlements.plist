<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!-- Hardened-runtime entitlements for the notarized PyInstaller bundle.
     Both are the standard requirements for frozen CPython: the interpreter
     JITs/ctypes into writable+executable pages, and the bootloader loads the
     bundled libpython outside the normal library-validation chain. -->
<plist version="1.0">
<dict>
  <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
  <true/>
  <key>com.apple.security.cs.disable-library-validation</key>
  <true/>
</dict>
</plist>
